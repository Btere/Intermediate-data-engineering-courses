_view_pk="_rowid_" freeze_columns="0"><sort><column index="4" mode="0"/></sort><column_widths><column index="1" value="79"/><column index="2" value="76"/><column index="3" value="54"/><column index="4" value="73"/><column index="5" value="97"/><column index="6" value="97"/><column index="7" value="32"/><column index="8" value="66"/><column index="9" value="131"/><column index="10" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="sqlite_sequence" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="118"/><column index="2" value="32"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="states" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="88"/><column index="2" value="94"/><column index="3" value="60"/><column index="4" value="103"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT first_name, id_number
FROM  people AS peo;

SELECT first_name, car_price_range

FROM my_sample_table  AS mst

INNER JOIN my_sample_table  AS mst
		ON peo.first_name = mst.first_name;
		
SELECT peo.first_name AS person_name,
       peo.id_number,
       mst.car_price_range,
       mst.marital_status
FROM people AS peo
LEFT JOIN my_sample_table AS mst
    ON peo.first_name = mst.first_name;
	
-- &lt;&gt; is SQL for “not equal” (same as != in some languages)
SELECT a.first_name AS person1,
       b.first_name AS person2,
       a.marital_status
FROM my_sample_table AS a
INNER JOIN my_sample_table AS b
    ON a.marital_status = b.marital_status
WHERE a.first_name &lt;&gt; b.first_name;

/* ... 
SELECT a.first_name AS person1,
	b.first_name AS person2,
	a.marital_status
FROM my_sample_table AS a
INNER JOIN my_sample_table AS b
ON a.marital_status = b.marital_staus
WHERE  a.first_name &lt;&gt; b.first_name;
*/	


--  UNION DISTINCT- combinating two or more tables based on conditions

SELECT first_name, 
	last_name;
	FROM people_in_manhantan
	UNION
	SELECT first_name, 
	last_name,
	FROM people
	ORDER BY last_name;


--  UNION ALL- combinating two or more tables based on conditions

SELECT first_name, last_name 
FROM people_in_manhantan
UNION ALL
SELECT first_name, last_name
FROM people
-- ORDER BY last_name;
GROUP BY first_name;


-- String functions in sqlite_sequence
SELECT 
    hair_color,
    same_age_bracket,
    is_active,
    library_books,
    LENGTH(library_books) AS library_length,
    UPPER(clothes_color) AS clothes_upper,
    -- REVERSE(hair_color) AS hair_reversed
FROM people_in_manhantan
WHERE same_age_bracket &lt;= 5;

-- case statement
SELECT 
    hair_color,
	first_name,
    same_age_bracket,
    is_active,
	clothes_color,
    library_books,
	CASE
		WHEN  first_name  LIKE '%i%'  THEN 'Young'
		WHEN clothes_color = 'blue'  OR  is_active  = 1 THEN  'active'
		WHEN clothes_color = 'black_and_white'  AND  is_active = 0 THEN  'Inactive'
		ELSE 'Unknown'
END AS status_label
FROM people_in_manhantan

-- wrong syntax subqueries
SELECT first_name,
		last_name,
FROM people_in_manhantan
WHERE id_number &lt; 5000 IN
															( SELECT  first_name, 
																last_name,
															FROM people
															WHERE id_number &lt;= 5)
;

-- right subquery syntax
SELECT first_name, last_name
FROM people_in_manhantan
WHERE id_number IN (
    SELECT id_number
    FROM people
    WHERE id_number &lt;= 6
);

SELECT *
FROM 
(SELECT  last_name, 
AVG(age)  AS avg_age,
MAX(age)  AS max_age,
MIN(age) AS min_age,
COUNT(age) AS count_age
FROM people_in_manhantan
GROUP BY last_name) AS aggr_table
;

-- Temporary tables--
CREATE  TABLE  #temp_Employee
 (EmployeeID INT,
JobTitle  VARCHAR (100),
Salary INT
);

FROM  #temp_Employee

INSERT INTO #temp_Employee VALUES(
100, 'HR', 46000);

INSERT INTO #temp_Employee
SELECT *
FROM SQLtutorial..EmployeeSalary;


CREATE TABLE  #temp_Employee
(
    EmployeeID INT,
    JobTitle VARCHAR(100),
    Salary INT
);

INSERT INTO #temp_Employee
VALUES (100, 'HR', 46000);

INSERT INTO #temp_Employee
SELECT *
FROM SQLtutorial..EmployeeSalary;

SELECT *
FROM #temp_Employee;
